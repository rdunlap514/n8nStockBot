        "responses": {
          "values": [
            {
              "content": "=You are a financial-market sentiment analyzer. Analyze the provided quote/news data for short-term sentiment.\n\nConsider:\n- Immediate market reaction\n- Recent news impact\n- Technical volatility where available\n- Whether the information is material, speculative, or stale\n\nReturn exactly one JSON object and no additional text. Use this exact structure:\n\n{\n  \"shortTermSentiment\": {\n    \"category\": \"Positive | Neutral | Negative\",\n    \"score\": 0.0,\n    \"rationale\": \"Concise explanation with the most relevant factors.\"\n  }\n}\n\nThe score must be between -1 and 1.\n\nData to analyze:\n{{ JSON.stringify({ quote: (($json.data || [])[1] || {}), companyNews: ((($json.data || [])[0] || {}).articles || []), tickerNews: ((($json.data || [])[2] || {}).articles || []) }) }}"
            }
          ]
        },
