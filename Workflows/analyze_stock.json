    {
      "parameters": {
        "jsCode": "const root = items[0].json;\nconst datasets = root.data || [];\n\nconst data1h = datasets[0] || {};\nconst data2h = datasets[1] || {};\nconst data8h = datasets[2] || {};\n\nfunction normalize(values = []) {\n  return values\n    .map(v => ({\n      time: new Date(v.datetime),\n      open: parseFloat(v.open),\n      high: parseFloat(v.high),\n      low: parseFloat(v.low),\n      close: parseFloat(v.close),\n      volume: parseFloat(v.volume),\n    }))\n    .filter(v => !Number.isNaN(v.close))\n    .sort((a, b) => a.time - b.time);\n}\n\nreturn [\n  {\n    json: {\n      ticker: data1h.meta?.symbol || data2h.meta?.symbol || data8h.meta?.symbol || null,\n      candles1h: normalize(data1h.values),\n      candles2h: normalize(data2h.values),\n      candles8h: normalize(data8h.values)\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        128
      ],
